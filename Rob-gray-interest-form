<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rob Gray Ireland – Priority Interest Form</title>
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --forest: #1a3a2a;
    --forest-mid: #254d38;
    --forest-light: #2f6347;
    --gold: #c9a84c;
    --gold-light: #e0c07a;
    --gold-pale: #f5e9c8;
    --cream: #faf6ee;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
    --border: #ddd8ce;
    --focus: #c9a84c;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
font-family: ‘Poppins’, sans-serif;
background: #f0ece3;
min-height: 100vh;
padding: 40px 16px 80px;
}

.wrapper {
max-width: 660px;
margin: 0 auto;
}

/* ── HEADER CARD ── */
.header-card {
background: var(–forest);
border-radius: 16px 16px 0 0;
padding: 48px 40px 40px;
position: relative;
overflow: hidden;
}
.header-card::before {
content: ‘’;
position: absolute;
top: -80px; right: -80px;
width: 260px; height: 260px;
border-radius: 50%;
background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%);
pointer-events: none;
}
.brand-line {
font-size: 10px;
font-weight: 700;
letter-spacing: 4px;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 20px;
display: flex;
align-items: center;
gap: 10px;
}
.brand-line::after {
content: ‘’;
flex: 1;
height: 1px;
background: rgba(201,168,76,0.3);
}
.header-card h1 {
font-family: ‘Lora’, serif;
font-size: clamp(1.6rem, 4vw, 2.2rem);
font-weight: 700;
color: var(–white);
line-height: 1.25;
margin-bottom: 16px;
}
.header-card h1 span { color: var(–gold); }
.header-card p {
font-size: 0.9rem;
color: rgba(255,255,255,0.72);
line-height: 1.7;
max-width: 520px;
}
.scarcity-bar {
margin-top: 28px;
background: rgba(255,255,255,0.07);
border: 1px solid rgba(201,168,76,0.3);
border-radius: 8px;
padding: 14px 18px;
display: flex;
align-items: center;
gap: 12px;
}
.scarcity-icon {
width: 32px; height: 32px;
background: rgba(201,168,76,0.15);
border-radius: 50%;
display: flex; align-items: center; justify-content: center;
font-size: 14px;
flex-shrink: 0;
}
.scarcity-text {
font-size: 0.82rem;
color: rgba(255,255,255,0.8);
line-height: 1.5;
}
.scarcity-text strong { color: var(–gold-light); }

/* ── FORM CARD ── */
.form-card {
background: var(–white);
padding: 0 40px 40px;
border-radius: 0 0 16px 16px;
box-shadow: 0 8px 40px rgba(26,58,42,0.12);
}

/* ── SECTION DIVIDER ── */
.section-divider {
border: none;
padding: 32px 0 8px;
display: flex;
align-items: center;
gap: 12px;
}
.section-divider-label {
font-size: 9px;
font-weight: 700;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–gold);
white-space: nowrap;
}
.section-divider-line {
flex: 1;
height: 1px;
background: var(–border);
}

/* ── QUESTION ── */
.question {
margin-bottom: 28px;
}
.question-header {
display: flex;
align-items: flex-start;
gap: 10px;
margin-bottom: 8px;
}
.q-num {
width: 22px; height: 22px;
background: var(–forest);
border-radius: 50%;
display: flex; align-items: center; justify-content: center;
font-size: 10px;
font-weight: 700;
color: var(–gold);
flex-shrink: 0;
margin-top: 2px;
}
label {
font-size: 0.9rem;
font-weight: 600;
color: var(–text);
line-height: 1.4;
display: block;
}
.required { color: var(–gold); margin-left: 2px; }
.hint {
font-size: 0.78rem;
color: var(–muted);
margin-top: 4px;
margin-left: 32px;
line-height: 1.5;
font-style: italic;
}

/* ── INPUTS ── */
input[type=“text”],
input[type=“email”],
textarea,
select {
width: 100%;
font-family: ‘Poppins’, sans-serif;
font-size: 0.88rem;
color: var(–text);
background: #faf8f4;
border: 1.5px solid var(–border);
border-radius: 8px;
padding: 12px 14px;
margin-top: 4px;
outline: none;
transition: border-color 0.2s, box-shadow 0.2s;
appearance: none;
}
input:focus, textarea:focus, select:focus {
border-color: var(–gold);
box-shadow: 0 0 0 3px rgba(201,168,76,0.15);
background: #fff;
}
textarea { resize: vertical; min-height: 90px; }

/* ── RADIO / CHECKBOX OPTIONS ── */
.options { margin-top: 8px; display: flex; flex-direction: column; gap: 8px; }
.option {
display: flex;
align-items: flex-start;
gap: 12px;
padding: 12px 14px;
border: 1.5px solid var(–border);
border-radius: 8px;
cursor: pointer;
transition: border-color 0.2s, background 0.2s;
background: #faf8f4;
}
.option:hover { border-color: var(–gold); background: #fffcf4; }
.option input[type=“radio”],
.option input[type=“checkbox”] {
width: 16px; height: 16px;
margin: 2px 0 0;
accent-color: var(–forest);
flex-shrink: 0;
cursor: pointer;
padding: 0;
border: none;
background: none;
box-shadow: none;
}
.option input:focus { box-shadow: none; border: none; }
.option-text {
font-size: 0.87rem;
color: var(–text);
line-height: 1.4;
}
.option-sub {
font-size: 0.76rem;
color: var(–muted);
margin-top: 2px;
font-style: italic;
}
.option.selected {
border-color: var(–forest);
background: rgba(26,58,42,0.04);
}

/* ── SCALE ── */
.scale-wrap { margin-top: 8px; }
.scale-labels {
display: flex;
justify-content: space-between;
font-size: 0.72rem;
color: var(–muted);
margin-bottom: 8px;
}
.scale-options {
display: flex;
gap: 8px;
}
.scale-option {
flex: 1;
text-align: center;
padding: 10px 4px;
border: 1.5px solid var(–border);
border-radius: 8px;
font-size: 0.85rem;
font-weight: 600;
color: var(–muted);
cursor: pointer;
background: #faf8f4;
transition: all 0.15s;
}
.scale-option:hover { border-color: var(–gold); color: var(–forest); background: #fffcf4; }
.scale-option.active { border-color: var(–forest); background: var(–forest); color: var(–gold); }

/* ── RATIONALE NOTES (for Kev’s reference — hidden on real form) ── */
.rationale {
margin-top: 8px;
margin-left: 32px;
background: linear-gradient(135deg, #f5e9c8, #eddcaa);
border-left: 3px solid var(–gold);
border-radius: 0 6px 6px 0;
padding: 10px 14px;
font-size: 0.75rem;
color: var(–forest-mid);
line-height: 1.6;
}
.rationale strong { font-weight: 700; color: var(–forest); }

/* ── SUBMIT ── */
.submit-section {
padding-top: 16px;
border-top: 1px solid var(–border);
margin-top: 8px;
}
.submit-note {
font-size: 0.8rem;
color: var(–muted);
margin-bottom: 16px;
line-height: 1.6;
font-style: italic;
}
.submit-btn {
width: 100%;
background: var(–forest);
color: var(–white);
border: none;
border-radius: 10px;
padding: 16px 24px;
font-family: ‘Poppins’, sans-serif;
font-size: 0.95rem;
font-weight: 600;
cursor: pointer;
transition: background 0.2s, transform 0.1s;
letter-spacing: 0.5px;
}
.submit-btn:hover { background: var(–forest-mid); transform: translateY(-1px); }
.submit-btn:active { transform: translateY(0); }
.submit-sub {
text-align: center;
font-size: 0.75rem;
color: var(–muted);
margin-top: 12px;
}

/* ── USAGE GUIDE ── */
.guide-card {
background: var(–forest);
border-radius: 12px;
padding: 28px 32px;
margin-top: 32px;
color: rgba(255,255,255,0.85);
}
.guide-card h3 {
font-family: ‘Lora’, serif;
font-size: 1.05rem;
color: var(–gold);
margin-bottom: 16px;
}
.guide-card p {
font-size: 0.83rem;
line-height: 1.7;
margin-bottom: 10px;
}
.guide-card p:last-child { margin-bottom: 0; }
.guide-card strong { color: var(–gold-light); }

/* ── LEGEND ── */
.legend {
display: flex;
align-items: center;
gap: 8px;
margin-bottom: 24px;
background: #fffcf4;
border: 1px solid var(–border);
border-radius: 8px;
padding: 12px 16px;
font-size: 0.78rem;
color: var(–muted);
}
.legend-dot {
width: 10px; height: 10px;
background: linear-gradient(135deg, #f5e9c8, #c9a84c);
border-radius: 2px;
flex-shrink: 0;
}

@media (max-width: 520px) {
.header-card, .form-card { padding-left: 22px; padding-right: 22px; }
.scale-option { padding: 8px 2px; font-size: 0.8rem; }
}
</style>

</head>
